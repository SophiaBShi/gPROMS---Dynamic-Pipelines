  <Group name="Miscellaneous Files">
    <MiscFileEntity name="scenario1_demands.input" version="2">
      <Properties>
        <StringProperty name="CreatedBy">sbs3348</StringProperty>
        <DateProperty name="CreatedDate">2026-02-17T20:44:05Z</DateProperty>
        <StringProperty name="ModifiedBy">sbs3348</StringProperty>
        <DateProperty name="ModifiedDate">2026-02-17T20:44:17Z</DateProperty>
        <StringProperty name="OriginalProject">OPT_scen1_20250513_102533_control_Q_2</StringProperty>
        <BooleanProperty name="Win32LineSeparation">true</BooleanProperty>
      </Properties>
      <Body><![CDATA[
# Input file for the 1D Linear Interpolation Foreign Object.
# Representing demand profiles from end users.

# 4 parameters, space delimited:  NameOfIndependentVariable1 xmin xmax nx 
mytime  0.0  86400  24

# number of dependent variables (N), followed by the names of each 
# dependent variables (N in total, one name per line).
4
demand1
demand2
demand3
demand4

# Data. Space separated list of N values of the dependent variables on a grid point. I.e.: 
#   o There are nx+1 lines of this type in total 
#   o The lines (i.e. grid points) are ordered so that y varies faster than x 

# Each row contains data for variables in the following order:
# demand1 demand2 deamnd3 demand4
27.87	0.01	6.34	0.67
27.87	0.01	6.34	0.67
28.04	0.01	6.34	0.53
28.22	0.01	6.34	0.37
28.39	0.01	6.34	0.33
28.56	0.01	6.34	0.32
28.74	0.01	6.34	0.40
28.91	0.01	6.34	0.58
