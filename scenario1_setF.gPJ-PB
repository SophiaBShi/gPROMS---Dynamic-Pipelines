      <PlotNode PlotLabel="" XAxisLabel="Time" YAxisLabel="Power" Y2AxisLabel="" showY2Axis="false" legend="true" symbols="false" layer="Layer 1" zorder="-9">
        <Transform ScaleX="436.0" ScaleY="243.0" ShearX="0.0" ShearY="0.0" TranslateX="3.446675031367292" TranslateY="643.355081555834"/>
        <Variable path="pipe1.ap.compr.Power_actual" label="compr 1" axis="y"/>
        <Variable path="pipe2.ap.compr.Power_actual" label="compr 2" axis="y"/>
      </PlotNode>
      <PlotNode PlotLabel="" XAxisLabel="Time" YAxisLabel="Pipe Deliver" Y2AxisLabel="" showY2Axis="false" legend="true" symbols="false" layer="Layer 1" zorder="-8">
        <Transform ScaleX="437.0" ScaleY="261.0" ShearX="0.0" ShearY="0.0" TranslateX="443.0" TranslateY="94.0"/>
        <Variable path="pipe1.ap.pipe.p(1)" label="to user 1" axis="y"/>
        <Variable path="pipe2.ap.pipe.p(1)" label="to user 234" axis="y"/>
      </PlotNode>
      <PlotNode PlotLabel="" XAxisLabel="Time" YAxisLabel="Outlet Flow" Y2AxisLabel="" showY2Axis="false" legend="true" symbols="false" layer="Layer 1" zorder="-7">
        <Transform ScaleX="431.0" ScaleY="273.0" ShearX="0.0" ShearY="0.0" TranslateX="4.000000000000014" TranslateY="360.0"/>
        <Variable path="demand1_interval" label="demand 1" axis="y"/>
        <Variable path="pipe2.ap.pipe.flow(1)" label="to user 1" axis="y"/>
        <Variable path="demand2_interval" label="demand 2" axis="y"/>
        <Variable path="demand3_interval" label="demand 3" axis="y"/>
        <Variable path="demand4_interval" label="demand 4" axis="y"/>
        <Variable path="split_node.Q_node" label="node" axis="y"/>
      </PlotNode>
      <PlotNode PlotLabel="" XAxisLabel="" YAxisLabel="nw daily cost" Y2AxisLabel="" showY2Axis="false" legend="true" symbols="false" layer="Layer 1" zorder="-12">
        <Transform ScaleX="329.00000000000017" ScaleY="267.00000000000006" ShearX="0.0" ShearY="0.0" TranslateX="889.0000000000001" TranslateY="366.0"/>
        <Variable path="daily_cost_nw" label="" axis="y"/>
      </PlotNode>
      <PlotNode PlotLabel="" XAxisLabel="" YAxisLabel="Inlet Flow" Y2AxisLabel="" showY2Axis="false" legend="true" symbols="false" layer="Layer 1" zorder="-13">
        <Transform ScaleX="430.0" ScaleY="268.00000000000006" ShearX="0.0" ShearY="0.0" TranslateX="6.0" TranslateY="85.99999999999994"/>
        <Variable path="pipe1.ap.compr.Q_sp" label="setpoint 1" axis="y"/>
        <Variable path="pipe1.ap.compr.Q" label="flow 1" axis="y"/>
        <Variable path="pipe2.ap.compr.Q_sp" label="setpoint 2" axis="y"/>
        <Variable path="pipe2.ap.compr.Q" label="flow 2" axis="y"/>
      </PlotNode>
      <UMS><![CDATA[]]></UMS>
      <Body><![CDATA[# Scenario Model builds the topology and initial setting for scenario 1, and calls the demand profiles

PARAMETER
no_steps            AS INTEGER
FREQ                AS REAL

P_user              AS ARRAY(4) OF REAL 
price_electricity   AS REAL DEFAULT 0.1 # $2022/kWh

demand_data         AS FOREIGN_OBJECT 


UNIT
pipe1               AS cost_pipe_active
split_node          AS node_passive
pipe2               AS cost_pipe_active


VARIABLE
mytime  AS anytype
STEPS1  AS ARRAY(no_steps) OF anytype
STEPS2  AS ARRAY(no_steps) OF anytype
STEPS3  AS ARRAY(no_steps) OF anytype
STEPS4  AS ARRAY(no_steps) OF anytype
UP1     AS ARRAY(no_steps) OF anytype
UP2     AS ARRAY(no_steps) OF anytype
UP3     AS ARRAY(no_steps) OF anytype
UP4     AS ARRAY(no_steps) OF anytype
DOWN1   AS ARRAY(no_steps) OF anytype
DOWN2   AS ARRAY(no_steps) OF anytype
DOWN3   AS ARRAY(no_steps) OF anytype
DOWN4   AS ARRAY(no_steps) OF anytype
demand1_interval AS Mass_Flow
demand2_interval AS Mass_Flow
demand3_interval AS Mass_Flow
demand4_interval AS Mass_Flow

# objective options
LCOH_nw         AS Cost_Levelized
LCOH_mile       AS Cost_Levelized
LCOH_p          AS Cost_Levelized
LCOH_c          AS Cost_Levelized

# -- to set up end-user pressure constraint --
diff_P          AS ARRAY(2) OF anytype
error_p_user    AS anytype

# -- to set up end-user flowrate constraint --
diff_flow       AS ARRAY(4) OF anytype
error_flow_user AS anytype

# --to set up end-point linepack constraint --
end_lp          AS ARRAY(2) OF Mass
diff_lp         AS ARRAY(2) OF anytype

# -- total flow --
total_daily_demand      AS anytype
total_daily_demand_mile AS anytype
daily_cost_nw           AS Cost_Daily

# -- Costs --
electricity_cost        AS anytype
energy                  AS Energy
OPEX_c                  AS anytype

# -- objective functions --
obj_energy              AS anytype
obj_LCOH                AS anytype
obj_LCOH_mile           AS anytype


SET
no_steps := 24 ;    # demand s each hour for 24 hours
FREQ := 3600 ;      # each hour has 3600 seconds

WITHIN split_node DO
    num_inlets := 1 ;
    num_outlets := 4 ;
END # within 

P_user(1:4) := 40 ;


EQUATION
# -- Topology connections --
# pipe 1 into the node --
pipe1.ap.pipe.P(1) = split_node.P_in(1) ;
pipe1.ap.pipe.flow(1) = split_node.Q_in(1) ;

# the node into pipe 2's compressor --
split_node.P_out(1) = pipe2.ap.compr.P_suc ;
split_node.Q_out(1) = pipe2.ap.compr.Q ;

# -- end-user pressure constraint --
diff_P(1) = pipe2.ap.pipe.p(1) - P_user(1); # End User 1
diff_P(2) = split_node.P_out(2) - P_user(2); # Enroute Users 2,3,4
#diff_P(3) = split_node.P_out(3) - P_user(3);
#diff_P(4) = split_node.P_out(4) - P_user(4); 
$error_p_user = SIGMA( (MAX(0,0-diff_p)/40)^2 ) ;

# -- for end-user demand constraint --
diff_flow(1) = pipe2.ap.pipe.flow(1) - demand1_interval; # End User 1
diff_flow(2) = split_node.Q_out(2) - (demand2_interval+0.4) ; # Enroute Users 2,3,4
diff_flow(3) = split_node.Q_out(3) - demand3_interval ;
diff_flow(4) = 10*(split_node.Q_out(4) - demand4_interval) ;
$error_flow_user = SIGMA( (MAX(0 ,0-diff_flow)/100)^2 ) ;

# -- for end-point linepack constraint --
diff_lp(1) = (pipe1.ap.pipe.linepack - end_lp(1))/1e6 ;
diff_lp(2) = (pipe2.ap.pipe.linepack - end_lp(2))/1e6 ;

# -- total flow --
$total_daily_demand = SIGMA(demand1_interval, demand2_interval, demand3_interval, demand4_interval) ;
$total_daily_demand_mile = (pipe1.ap.pipe.L + pipe2.ap.pipe.L)/1609.43 * demand1_interval # End User 1
                          +(pipe1.ap.pipe.L)/1609.43 * SIGMA(demand2_interval, demand3_interval, demand4_interval) ; # Enroute User 2,3,4

# -- energy --
energy = SIGMA(pipe1.energy_consumption, pipe2.energy_consumption) ;
electricity_cost  = energy * price_electricity ;
OPEX_c = electricity_cost + SIGMA(pipe1.c_NE_OPEX, pipe2.c_NE_OPEX);

# -- costs --
LCOH_p * (total_daily_demand) = SIGMA((pipe1.p_daily_CAPEX + pipe1.p_OPEX), (pipe2.p_daily_CAPEX + pipe2.p_OPEX));
LCOH_c * (total_daily_demand) = SIGMA(pipe1.c_daily_CAPEX, pipe2.c_daily_CAPEX, OPEX_c) ;

daily_cost_nw = SIGMA(OPEX_c, 
                pipe1.c_daily_CAPEX,
                pipe1.p_daily_CAPEX, pipe1.p_OPEX,
                pipe2.c_daily_CAPEX,
                pipe2.p_daily_CAPEX, pipe2.p_OPEX) ;
LCOH_nw * total_daily_demand  = daily_cost_nw * 1000;  # $/ton
LCOH_mile * total_daily_demand_mile = daily_cost_nw * 1000 * 100 ; # $/ton per 100 miles

# -- Objective funcitons --
obj_energy = energy / 1e5;
obj_LCOH = LCOH_nw ; 
obj_LCOH_mile = LCOH_mile + error_flow_user*10 ;

#--- run foreign object---------------------------------------------------------------------------------------------------------------
# -- let mytime = TIME --
$mytime = 1 ;

# END-USER 1 DEMAND SCHEDULE/PROFILE REPRESENTED IN GRANULARITY OF SECONDS 

FOR j:= 1 TO no_steps DO
   STEPS1(j) = (demand_data.demand1(j * FREQ) - demand_data.demand1((j-1) * FREQ));
END

FOR j:= 1 TO no_steps DO
   UP1(j) =   + 1/2 * (1 + sgn(Mytime - ((j-1)*2 + j*FREQ))) * 1/2 * STEPS1(j) * (Mytime - ((j-1)*2 + j*FREQ));
   DOWN1(j) = - 1/2 * (1 + sgn(Mytime - (j*2 + j*FREQ))) * 1/2 * STEPS1(j) * (Mytime - (j*2 + j*FREQ));
END

demand1_interval = demand_data.demand1(1) + SIGMA(UP1() + DOWN1()) ; 

# END-USER 2 DEMAND SCHEDULE/PROFILE REPRESENTED IN GRANULARITY OF SECONDS 

FOR j:= 1 TO no_steps DO
   STEPS2(j) = (demand_data.demand2(j * FREQ) - demand_data.demand2((j-1) * FREQ));
END

FOR j:= 1 TO no_steps DO
   UP2(j) =   + 1/2 * (1 + sgn(Mytime - ((j-1)*2 + j*FREQ))) * 1/2 * STEPS2(j) * (Mytime - ((j-1)*2 + j*FREQ));
   DOWN2(j) = - 1/2 * (1 + sgn(Mytime - (j*2 + j*FREQ))) * 1/2 * STEPS2(j) * (Mytime - (j*2 + j*FREQ));
END

demand2_interval = demand_data.demand2(1) + SIGMA(UP2() + DOWN2()) ; 

# END-USER 3 DEMAND SCHEDULE/PROFILE REPRESENTED IN GRANULARITY OF SECONDS 

FOR j:= 1 TO no_steps DO
   STEPS3(j) = (demand_data.demand3(j * FREQ) - demand_data.demand3((j-1) * FREQ));
END

FOR j:= 1 TO no_steps DO
   UP3(j) =   + 1/2 * (1 + sgn(Mytime - ((j-1)*2 + j*FREQ))) * 1/2 * STEPS3(j) * (Mytime - ((j-1)*2 + j*FREQ));
   DOWN3(j) = - 1/2 * (1 + sgn(Mytime - (j*2 + j*FREQ))) * 1/2 * STEPS3(j) * (Mytime - (j*2 + j*FREQ));
END

demand3_interval = demand_data.demand3(1) + SIGMA(UP3() + DOWN3()) ; 

# END-USER 4 DEMAND SCHEDULE/PROFILE REPRESENTED IN GRANULARITY OF SECONDS 

FOR j:= 1 TO no_steps DO
   STEPS4(j) = (demand_data.demand4(j * FREQ) - demand_data.demand4((j-1) * FREQ));
END

FOR j:= 1 TO no_steps DO
   UP4(j) =   + 1/2 * (1 + sgn(Mytime - ((j-1)*2 + j*FREQ))) * 1/2 * STEPS4(j) * (Mytime - ((j-1)*2 + j*FREQ));
   DOWN4(j) = - 1/2 * (1 + sgn(Mytime - (j*2 + j*FREQ))) * 1/2 * STEPS4(j) * (Mytime - (j*2 + j*FREQ));
END

demand4_interval = demand_data.demand4(1) + SIGMA(UP4() + DOWN4()) ; 
#--- run foreign object---------------------------------------------------------------------------------------------------------------


INITIAL
mytime = 0 ;

pipe1.energy_consumption = 0 ;
pipe2.energy_consumption = 0 ;

#error_p_user = 0 ;
#error_flow_user = 0 ;]]></Body>
    </ModelEntity>
  </Group>
  <Group name="Processes">
    <ProcessEntity name="simulate_scenario1_setF" version="1">
      <Properties>
        <StringProperty name="CreatedBy">sbs3348</StringProperty>
        <DateProperty name="CreatedDate">2025-05-07T22:21:40Z</DateProperty>
        <StringProperty name="ModifiedBy">sbs3348</StringProperty>
        <DateProperty name="ModifiedDate">2026-02-17T20:43:47Z</DateProperty>
        <StringProperty name="OriginalProject">OPT_scen1_20250513_102533_control_Q_2</StringProperty>
        <StringProperty name="SimulationExecutionDirectory"></StringProperty>
        <BooleanProperty name="IncludeUnitSpecifications">true</BooleanProperty>
        <BooleanProperty name="IncludeInitialisationProcedure">true</BooleanProperty>
      </Properties>
      <Body><![CDATA[# Scenario Process simulates scenario 1 with the called demand profile and defined compressor operations

UNIT
nw AS scenario1


MONITOR # variables of interest
# for the whole system
nw.LCOH_nw ;
nw.LCOH_mile ;
nw.energy ;
nw.daily_cost_nw ;

# for compressors
nw.LCOH_c
nw.pipe*.ap.compr.Q_sp ;
nw.pipe*.ap.compr.Q ;
nw.pipe*.ap.compr.P_disc ;
nw.pipe*.ap.compr.compr_ratio ;
nw.pipe*.ap.compr.Power_actual ;
nw.pipe*.energy_consumption ;

# for pipeline segments
nw.LCOH_p
nw.pipe*.ap.pipe.linepack ;
nw.pipe*.ap.pipe.p ;
nw.pipe*.ap.pipe.flow ;
nw.pipe*.ap.pipe.rho ;

# for all node
nw.split_node*.P_node; # delibery to users 2, 3, 4

# if want all variables
nw.* ;


SET
WITHIN nw DO 
    # Linearly interpolate the hourly demand profile
    demand_data := "Linear1DInterpolantFO::scenario1_demands.input" ;

    WITHIN pipe1 DO 
        WITHIN ap.pipe DO 
            L               := 321869 ; # 200 miles
            Z               := 1.031 ; #1.02 ; # @ T and P
            N_interval      := 5 ;

            # -- distribution domain --
            axial := [CFDM, 2, N_interval] ;
        END # ap.pipe
    END # pipe1

    WITHIN pipe2 DO 
        WITHIN ap.pipe DO 
            L               := 112654 ; # 100 miles
            Z               := 1.031 ; #1.02 ; # @ T and P
            N_interval      := 5 ;

            # -- distribution domain --
            axial := [CFDM, 2, N_interval] ;
        END # ap.pipe
    END # pipe2
end # nw


ASSIGN 
WITHIN nw DO 
    # -- minimum linepack to be preserved --
    end_lp(1) := 931200 ;
    end_lp(2) := 183100 ;

    # -- pressure requirements are met strictly --
    diff_p := 0 ; 

    WITHIN pipe1 DO 
        base_flow := 34.88899543 ;
        WITHIN ap.pipe DO 
            T := 288.15 ;
            D := 40 * 0.0254 ; # m
        END # pipe

        WITHIN ap.compr DO
            num_unit := 222 ; 
            T_suc := 288.15 ;
            P_suc := 20 ; 
            Q_sp := 34.9 ; 
            Z := 1.024; 
        END # compr
    END # pipe1

    # -- operation  ------------------------------------ 
    WITHIN nw DO 
        nw.diff_flow(4) := 0 ; # replaces Q_out(2) as decision variable
        WITHIN split_node DO
            # -- demands at the node --
            Q_out(3) := 6.341958397 ; # demand3_interval ;
         END # within split
    END # nw
    #---------------------------------------------------

    WITHIN pipe2 DO 
        base_flow := 27.87 ;
        WITHIN ap.pipe DO 
            T := 288.15 ;
            D := 30 * 0.0254 ; # m
        END # pipe

        WITHIN ap.compr DO
            num_unit := 26 ; # num_unit = max power / power rating 560 kW of each compressor
            T_suc := 288.15 ;
            Q_sp := 27.87 ; # COMMENT OUT FOR SIMULATION!!
            Z := 1.024; 
        END # compr
    END # pipe1
end # ap


INITIALSELECTOR
WITHIN nw DO 
    pipe1.ap.pipe.SystemStatus := pipe1.ap.pipe.dynamic_set_flow_in ;
    pipe2.ap.pipe.SystemStatus := pipe2.ap.pipe.dynamic_set_flow_in ;
END # nw


INITIAL
WITHIN nw DO 
    WITHIN pipe1 DO 
        $(ap.compr.Q) = 0 ;
        $(ap.pipe.rho(0:1|-)) = 0;
        $(ap.pipe.q(0|+:1)) = 0 ;
    END # pipe1 

    WITHIN pipe2 DO 
        $(ap.compr.Q) = 0 ;
        $(ap.pipe.rho(0:1|-)) = 0;
        $(ap.pipe.q(0|+:1)) = 0 ;
    END # pipe1 

    nw.error_p_user = 0 ;
    error_flow_user = 0 ;

    total_daily_demand = 34.88899543;
    total_daily_demand_mile = (nw.pipe1.ap.pipe.L + nw.pipe2.ap.pipe.L)/1609.43 * 27.87037
                             +(nw.pipe1.ap.pipe.L)/1609.43 * (34.88899543-27.87037) ;
END # nw



SOLUTIONPARAMETERS
    DASolver := "DAEBDF" [
        "ErrorNormComputation" := "DifferentialAndScaledAlgebraic",
        "OutputLevel" := 2
    ]
    DOSolver := "CVP_SS" [
        "MINLPSolver" := "NLPSQP" [
            "OptimisationTolerance" := 0.01
        ]
    ]
    IndexReduction := ON
SCHEDULE
CONTINUE FOR 86400
]]></Body>
    </ProcessEntity>
  </Group>
  <Group name="Optimisations">
    <OptimisationEntity name="FDO_scenario1" version="2">
      <Properties>
        <StringProperty name="CreatedBy">sbs3348</StringProperty>
