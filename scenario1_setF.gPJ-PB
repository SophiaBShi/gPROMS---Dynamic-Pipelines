      <UMS><![CDATA[]]></UMS>
      <Body><![CDATA[# Cost Model

PARAMETER
# -- for a large reciprocating compressor --
c_lifetime                  AS INTEGER
installation_factor         AS REAL  

# -- for a pipeline segment --
p_lifetime                  AS INTEGER  

# -- shared parameters --
discount_rate               AS REAL             
labor_rate                  AS REAL 


UNIT
to2022                      AS Financial_2022
ap                          AS pipe_active_setF


VARIABLE
base_flow                   AS Mass_FLow  # designed nominal flow

# -- costs for a compressor station --
c_CAPEX                     AS Cost # total capital investment
c_TIC                       AS Cost # total instlled costs
c_UC                        AS Cost # uninstalled cost
c_indirect_cost AS Cost
# --
c_direct_labor              AS Cost_Daily
c_labor_daily_hours         AS anytype
c_indirect_labor            AS Cost_Daily
c_FOM                       AS Cost_Daily
c_NE_OPEX                   AS Cost_Daily
# --
c_daily_CAPEX               AS Cost_Daily
c_daily_TIC                 AS Cost_Daily 
c_CRF                       AS anytype # capital recovery factor
# -- electricty
energy_consumption          AS Energy

# -- costs for a pipeline segment --
p_CAPEX                     AS Cost   # total capital investment
p_TIC                       AS Cost   # total installed costs
p_indirect_cost             AS Cost
p_material                  AS Cost
p_cap_labor                 AS Cost
p_misc                      AS Cost
p_ROW                       AS Cost # right-of-way costs
# --
p_OPEX                      AS Cost_Daily
p_direct_labor              AS Cost_Daily
p_labor_daily_hours         AS anytype
p_indirect_labor            AS Cost_Daily
p_FOM                       AS Cost_Daily # fixed O&M costs
# --
p_daily_CAPEX               AS Cost_Daily
p_daily_TIC                 AS Cost_daily
p_CRF                       AS anytype  # capital recovery factor


SET
# -- for a large reciprocating compressor --
c_lifetime := 15 ;     # years
installation_factor := 2 ; # for high flow and moderate compression, IF = the labor or parts required to install compressor

# -- for a pipeline segment --
p_lifetime := 30 ;     # years

# -- shared parameters --
discount_rate := 0.08 ;   # 8%, weighted average cost of capital (WACC)                
labor_rate := 31.60 * to2022.inflation_rate_from('2014') ; # 2022$/hour


EQUATION
# -- costs for a compressor --
c_CAPEX = c_TIC + c_indirect_cost ;
c_indirect_cost = (0.05 + 0.10 + 0.10 + 0.03 + 0.12) * c_TIC ;
c_TIC = c_UC * installation_factor ;
c_UC = 1962.2 * (ap.compr.num_unit * ap.compr.Power_max)^0.8225 * to2022.inflation_rate_from('2007'); # 2022$
# --
c_daily_CAPEX = c_CAPEX * c_CRF / 365 ;
c_daily_TIC = c_TIC * c_CRF /365 ;
c_CRF = discount_rate * (discount_rate + 1)^c_lifetime / ((discount_rate+1)^c_lifetime - 1) ;
# -- 
# compressor OPEX
# non-energy, or FOM
c_NE_OPEX = c_direct_labor + c_indirect_labor + c_FOM ;
c_FOM = (0.01 + 0.01 + 0.001) * c_daily_CAPEX + 0.04 * c_daily_TIC + 0.5 * c_direct_labor;
c_direct_labor = c_labor_daily_hours * labor_rate ;
c_labor_daily_hours = 288 * (base_flow*24*3600 / 100000)^0.25 / 365 ;
c_indirect_labor = 0.5 * c_direct_labor ;
# -- 
$energy_consumption * 3600 = (ap.compr.Power_actual)/1000 ; 
# electricity (energy), c_OPEX (VOM) is calculated at the network level

# -- costs for a pipeline segment --
p_CAPEX = p_TIC + p_indirect_cost ;
p_indirect_cost = (0.05 + 0.10 + 0.10 + 0.03) * p_TIC ; 
p_TIC = (p_material + p_cap_labor + p_misc + p_ROW)  * (ap.pipe.L/1609.34) * (ap.pipe.D/0.0254) ; # 2022$
p_material = 5605 * (ap.pipe.D/0.0254)^0.41642 / (ap.pipe.L/1609.34)^0.06441 * to2022.inflation_rate_from('2019'); # 2022$/mile-inch
p_cap_labor = 95295 * (ap.pipe.L/1609.34)^0.03070 / (ap.pipe.D/0.0254)^0.53848 * to2022.inflation_rate_from('2019');
p_misc = 19211 / (ap.pipe.D/0.0254)^0.14178 / (ap.pipe.L/1609.34)^0.04697 * to2022.inflation_rate_from('2019') ;
p_ROW = 72634 * (ap.pipe.L/1609.34)^0.05284 / (ap.pipe.D/0.0254)^1.07566 * to2022.inflation_rate_from('2019') ;
# --
p_daily_CAPEX = p_CAPEX * p_CRF / 365 ;
p_daily_TIC = p_TIC * p_CRF / 365 ;
p_CRF = discount_rate * (discount_rate + 1)^p_lifetime / ((discount_rate + 1)^p_lifetime - 1) ;
# --
# Fixed OPEX (non-energy)
p_OPEX = p_direct_labor + p_indirect_labor + p_FOM ;
p_FOM = (0.01 + 0.01 + 0.001) * p_daily_CAPEX + 0.01 * p_daily_TIC + 0.5 * p_direct_labor ;
p_direct_labor = p_labor_daily_hours * labor_rate ;
p_labor_daily_hours = 8320 * (base_flow *3600*24 / 100000)^0.25 / 365; # hours/day
p_indirect_labor = 0.5 * p_direct_labor ;]]></Body>
    </ModelEntity>
