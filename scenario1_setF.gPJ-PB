      <Body><![CDATA[# Index Model to convert dollar values considering depreciation

PARAMETER
reference_year_list         AS ORDERED_SET
CEPCI                       AS ARRAY(reference_year_list)       OF REAL 

SET
reference_year_list := [
#'1990',
#'1991',
#'1992',
#'1993',
#'1994',
#'1995',
#'1996',
#'1997',
#'1998',
#'1999',
#'2000',
#'2001',
#'2002',
#'2003',
#'2004',
#'2005',
'2006',
'2007',
'2008',
'2009',
'2010',
'2011',
'2012',
'2013',
'2014',
'2015',
'2016',
'2017',
'2018',
'2019',
#'2020',
#'2021',
'2022',
'2023'];

CEPCI('2006') := 499.6 ;
CEPCI('2007') := 525.4 ;
CEPCI('2008') := 575.4 ;
CEPCI('2009') := 521.9 ;
CEPCI('2010') := 550.8 ;
CEPCI('2011') := 585.7 ;
CEPCI('2012') := 584.6 ;
CEPCI('2013') := 567.3 ;
CEPCI('2014') := 576.1 ;
CEPCI('2015') := 556.8 ;
CEPCI('2016') := 541.7 ;
CEPCI('2017') := 572.8 ;
CEPCI('2018') := 572.8 ;
CEPCI('2019') := 619.2 ;
CEPCI('2022') := 817.4 ;
CEPCI('2023') := 797.9 ;

]]></Body>
    </ModelEntity>
