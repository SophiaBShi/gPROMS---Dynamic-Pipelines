      <Body><![CDATA[# Bypass Node Model with customizable # of inlets and outlets
# Energy and mass balance applied

PARAMETER
num_inlets      AS INTEGER
num_outlets     AS INTEGER 


VARIABLE
P_in        AS ARRAY(num_inlets) OF Pressure
P_out       AS ARRAY(num_outlets) OF Pressure
Q_in        AS ARRAY(num_inlets) OF Mass_Flow
Q_out       AS ARRAY(num_outlets) OF Mass_Flow

P_node      AS Pressure
Q_node      AS Mass_FLow


EQUATION
# -- Mass Balance --
Q_node = SIGMA(Q_in) ;
Q_node = SIGMA(Q_out) ;

# -- Energy Balance --
P_node = MIN(P_in()) ;
P_node = P_out() ;]]></Body>
    </ModelEntity>
