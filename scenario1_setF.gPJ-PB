      <Body><![CDATA[# Convertion Model to convert all dollar values to 2022 dollar value

PARAMETER
reference_year_list         AS ORDERED_SET
inflation_rate_from      AS ARRAY(reference_year_list)   OF REAL  


UNIT
CEPCI                       AS CEPCI_index


SET
reference_year_list := [
#'1990',
#'1991',
#'1992',
#'1993',
#'1994',
#'1995',
#'1996',
#'1997',
#'1998',
#'1999',
#'2000',
#'2001',
#'2002',
#'2003',
#'2004',
#'2005',
'2006',
'2007',
'2008',
'2009',
'2010',
'2011',
'2012',
'2013',
'2014',
'2015',
'2016',
'2017',
'2018',
'2019',
#'2020',
#'2021',
'2022'];

inflation_rate_from('2006') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2006') ;
inflation_rate_from('2007') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2007') ;
inflation_rate_from('2008') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2008') ;
inflation_rate_from('2009') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2009') ;
inflation_rate_from('2010') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2010') ;
inflation_rate_from('2011') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2011') ;
inflation_rate_from('2012') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2012') ;
inflation_rate_from('2013') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2013') ;
inflation_rate_from('2014') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2014') ;
inflation_rate_from('2015') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2015') ;
inflation_rate_from('2016') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2016') ;
inflation_rate_from('2017') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2017') ;
inflation_rate_from('2018') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2018') ;
inflation_rate_from('2019') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2019') ;
inflation_rate_from('2022') := CEPCI.CEPCI('2022')/CEPCI.CEPCI('2022') ;
 ]]></Body>
    </ModelEntity>
