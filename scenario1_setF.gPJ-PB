      <Body><![CDATA[# Passive Pipe Segment Model with Euler's PDE

PARAMETER
# Physical Constants
R                      AS                          REAL DEFAULT 8.314          # Gas constant (J/mol*K)
pi                     AS                          REAL DEFAULT 3.14159265359  # Pi
g                      AS                          REAL DEFAULT 9.81           # Gravitational constant (m/s^2)

# pipe parameters
roughness              AS                          REAL DEFAULT 0.0000178      # m 
L                      AS                          REAL                        # m, value is set in Process

# Hydrogen as parameters
k                      AS                          REAL DEFAULT 1.41           # Cp/Cv, for H2
molar_weight           AS                          REAL DEFAULT 2.016/1000     # kg/mol
Z                      AS                          REAL                        # Compresibility facor, set in Process
viscosity              AS                          REAL DEFAULT 8.7e-6         # kg/m-s          
SG                     AS                          REAL DEFAULT 0.0696         # specific gravity of gas (density ratio to air)

# discretization
N_interval              AS                         INTEGER                     # value is set in process


DISTRIBUTION_DOMAIN
# -- Normalize pipe length to 1 --
axial                  AS [0 : 1] 


VARIABLE 
D       AS                                 Diameter     # m
area    AS                                 anytype      # m^2
lambda  AS      Friction_Factor
T       AS      Temperature                             # K
a2      AS      anytype                                 # J/kg, or m^2/s^2
linepack AS     Mass                                    # kg
p       AS      DISTRIBUTION(axial)     OF Pressure     # bar
q       AS      DISTRIBUTION(axial)     OF Mass_Flux    # kg/s-m^2
rho     AS      DISTRIBUTION(axial)     OF Density      # kg/m^3
v       AS      DISTRIBUTION(axial)     OF Velocity     # m/s
v_max   AS      DISTRIBUTION(axial)     OF Velocity     # m/s   
flow    AS      DISTRIBUTION(axial)     OF Mass_Flow    # kg/s

# -- for setting constraints in optimization --
p_critical      AS Pressure
error_erosion AS anytype
error_choke AS anytype


SELECTOR
SystemStatus AS (stst, dynamic_set_pres_in, dynamic_set_flow_in) DEFAULT stst


EQUATION 
# --- General pipeline equations --- 
area = pi/4 * D^2 ;
a2      = Z * R * T / molar_weight ;       
p       = a2 * rho /1e5;                    # (kg/m-s^2 or Pa) TO BAR *by dividing 1e5
q       = rho * v ;                       
flow    = q * area ;
1/SQRT(lambda) = -2*LOG10(roughness/(3.71*D)) ;
linepack = area * INTEGRAL(x:=0:1 ; rho(x)) * L ;

# -- for setting up constraints in optimization --
# Erosional velocity:
v_max = 100 * SQRT(0.5131 * Z * R * T /(SG * (p*100))) ; # 1 bar = 100 kPa
$error_erosion = SIGMA( (MAX(0, v(0:1)-v_max(0:1))/100)^2 ) ;

# Chocked condition: 
p_critical = p(0) * (2/(k+1))^(k/(k-1)) ;
$error_choke = ( MIN(0, p(1)-p_critical)/30 )^2 ;

# -- PDE cases --
CASE SystemStatus OF 
    WHEN stst:
        FOR x := 0|+ TO 1 DO
            (1/L) * PARTIAL(q(x),axial) = 0 ; 
            (1/L) * PARTIAL(P(x)*1e5, axial)  = - lambda/(2*D*rho(x)) *q(x) * ABS(q(x))  ;
        END # for

    WHEN dynamic_set_pres_in:
        FOR x := 0|+ TO 1 DO
            $rho(x) +  (1/L) * PARTIAL(q(x),axial) = 0 ; 
        END # for

        FOR x := 0 TO 1|- DO
            $q(x) +  (1/L) * PARTIAL(P(x)*1e5, axial)  = - lambda/(2*D*rho(x)) *q(x) * ABS(q(x))  ;
        END # for

    WHEN dynamic_set_flow_in:
        FOR x := 0 TO 1|- DO
            $rho(x) +  (1/L) * PARTIAL(q(x),axial) = 0 ; 
        END # for

        FOR x := 0|+ TO 1 DO
            $q(x) +  (1/L) * PARTIAL(P(x)*1e5, axial)  = - lambda/(2*D*rho(x)) *q(x) * ABS(q(x))  ;
        END # for
END # case


INITIAL
error_erosion = 0 ;
error_choke = 0 ;]]></Body>
    </ModelEntity>
    <ModelEntity name="recip_compressor_setF" version="8" UnitNameShown="true" UnitModelShown="false" AutoRouteConnections="true">
      <Properties>
        <StringProperty name="CreatedBy">sbs3348</StringProperty>
        <DateProperty name="CreatedDate">2025-05-05T20:03:06Z</DateProperty>
        <StringProperty name="ModifiedBy">sbs3348</StringProperty>
        <DateProperty name="ModifiedDate">2026-02-17T20:10:38Z</DateProperty>
        <StringProperty name="OriginalProject">OPT_scen1_20250513_102533_control_Q_2</StringProperty>
        <StringProperty name="DefaultTab">topology</StringProperty>
        <StringProperty name="DefaultCaseTab">reports</StringProperty>
        <BooleanProperty name="DisplayedInPalette">false</BooleanProperty>
        <BooleanProperty name="RecycleBreaker">false</BooleanProperty>
        <BooleanProperty name="IncludeInitialisationProcedure">true</BooleanProperty>
      </Properties>
      <Icon>-199773695</Icon>
      <FlowsheetLayers DefaultLayer="Layer 1">
        <Layer name="Layer 1" visible="true" printed="true"/>
      </FlowsheetLayers>
      <UMS><![CDATA[]]></UMS>
      <Body><![CDATA[# Reciprocating Compressor Model with Flowrate Settings

PARAMETER
# -- Constants --
R               AS  REAL    DEFAULT     8.314       # J/mol-K
k               AS  REAL    DEFAULT     1.406       #Cp = 14.31 kJ/kg-K, Cv = 10.18 kJ/kg-K @ room temp and standard pressure for hydrogen; for NG, Cp=2.25, Cv=1.73
MW              AS  REAL    DEFAULT     2.016e-3    # kg/mol
  

# -- Compressor Parameters --
eta_isen        AS  REAL                            # isentropic efficiency
eta_motor       AS  REAL                            # motor efficiency
Power_max       AS  REAL DEFAULT 560                # kW

# -- for first-order filter --
tau_Q           AS REAL DEFAULT 5                   # s


VARIABLE
Z               AS  anytype
Q               AS  Mass_Flow                       # kg/s
P_suc, P_disc   AS  Pressure                        # bar
T_suc           AS  anytype                         # K
Power_multi, Power_actual   AS Power                # W

# -- for constraints in optimization
compr_ratio                 AS anytype
error_compr_ratio           AS anytype

# -- compressor station design --
num_unit        AS anytype  # number of total compressors in the compressor station, value is set in process

# -- for first-order filter --
Q_sp    AS Mass_Flow
err_Q   AS anytype


SET
eta_isen := 0.8 ;
eta_motor := 0.95 ;


EQUATION
IF compr_ratio < 1.001 THEN # no compression needed
    Power_multi = 0 ;
ELSE 
    Power_multi = (k/(k-1)) * (Z/eta_isen) * T_suc * (Q/MW) * R * ((P_disc/P_suc)^((k-1)/k) - 1 ) ;
END # if

# -- Rated compressor power --
Power_actual = Power_multi/eta_motor ;

# -- for setting up constraints in optimization
# Compression ratio:
compr_ratio = P_disc/P_suc ;
$error_compr_ratio = ( MAX(0, 1-compr_ratio, compr_ratio-5)/3.1 )^2 ;

# -- first-order filter for flowrate changes --
err_Q = Q_sp - Q ;
$Q = 1/tau_Q * err_Q ;



INITIAL
error_compr_ratio = 0 ;]]></Body>
    </ModelEntity>
